{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Definition of Definition",
  "description": "Meta-schema: every attribute in the system must answer these five questions. This is the governance contract.",
  "type": "object",
  "required": ["field_name", "where", "what_format", "who_responsible", "who_has_access", "why_exists"],
  "properties": {
    "field_name": {
      "type": "string",
      "description": "The canonical name of the attribute"
    },
    "where": {
      "type": "object",
      "description": "Q1: Where does it live — which system owns it, is this a copy",
      "required": ["owning_system", "is_copy"],
      "properties": {
        "owning_system": {
          "type": "string",
          "description": "The system of record for this attribute"
        },
        "is_copy": {
          "type": "boolean",
          "description": "True if this is a derived or copied value from another system"
        },
        "source_system": {
          "type": "string",
          "description": "If is_copy is true, which system is the original source"
        },
        "sync_frequency": {
          "type": "string",
          "enum": ["real_time", "daily", "weekly", "manual", "never"],
          "description": "How often this copy is refreshed from source"
        }
      }
    },
    "what_format": {
      "type": "object",
      "description": "Q2: What format — type, length, units, allowed values, null handling",
      "required": ["data_type", "nullable"],
      "properties": {
        "data_type": {
          "type": "string",
          "enum": ["string", "number", "integer", "boolean", "date", "datetime", "enum", "array", "object"],
          "description": "The data type of this attribute"
        },
        "max_length": {
          "type": "integer",
          "description": "Maximum character length for string types"
        },
        "unit": {
          "type": "string",
          "description": "Unit of measurement (mm, kg, EUR, etc.)"
        },
        "precision": {
          "type": "integer",
          "description": "Decimal precision for number types"
        },
        "allowed_values": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Enumerated list of allowed values"
        },
        "pattern": {
          "type": "string",
          "description": "Regex pattern for validation"
        },
        "nullable": {
          "type": "boolean",
          "description": "Whether null/empty values are permitted"
        },
        "default_value": {
          "description": "Default value when not provided"
        }
      }
    },
    "who_responsible": {
      "type": "object",
      "description": "Q3: Who is responsible — who creates, who can change, who resolves conflicts",
      "required": ["creator_role", "editor_roles"],
      "properties": {
        "creator_role": {
          "type": "string",
          "description": "Role that initially creates this value"
        },
        "editor_roles": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Roles permitted to modify this value"
        },
        "conflict_resolver": {
          "type": "string",
          "description": "Role that resolves conflicts when values disagree"
        },
        "review_cycle": {
          "type": "string",
          "enum": ["continuous", "quarterly", "annual", "on_change", "never"],
          "description": "How often this value is reviewed for accuracy"
        }
      }
    },
    "who_has_access": {
      "type": "object",
      "description": "Q4: Who has access — read/write/delete/history per role",
      "required": ["access_rules"],
      "properties": {
        "access_rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["role", "permissions"],
            "properties": {
              "role": {
                "type": "string",
                "description": "The role (customer, sales, engineer, management)"
              },
              "permissions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["read", "write", "delete", "history"]
                },
                "description": "Permitted operations for this role"
              }
            }
          }
        },
        "classification": {
          "type": "string",
          "enum": ["public", "internal", "restricted", "confidential"],
          "description": "Data classification level"
        }
      }
    },
    "why_exists": {
      "type": "object",
      "description": "Q5: Why does it exist — what decision does this serve, what breaks if wrong",
      "required": ["decision_supported", "impact_if_wrong"],
      "properties": {
        "decision_supported": {
          "type": "string",
          "description": "The business decision this attribute supports"
        },
        "impact_if_wrong": {
          "type": "string",
          "enum": ["safety_critical", "financial_loss", "operational_delay", "cosmetic", "none"],
          "description": "Severity of impact if this value is incorrect"
        },
        "downstream_consumers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Systems or views that depend on this value"
        }
      }
    },
    "governance": {
      "type": "object",
      "description": "Metadata about the definition itself",
      "properties": {
        "defined_by": {
          "type": "string",
          "description": "Who created this definition"
        },
        "defined_at": {
          "type": "string",
          "format": "date-time",
          "description": "When this definition was created"
        },
        "version": {
          "type": "integer",
          "description": "Version number of this definition"
        },
        "review_date": {
          "type": "string",
          "format": "date",
          "description": "Next scheduled review date"
        }
      }
    }
  }
}
