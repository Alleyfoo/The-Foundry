{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Industrial Fastener — Source Schema (Single Source of Truth)",
  "description": "Canonical schema for all product attributes. Every field here is the authoritative definition. View schemas derive from this.",
  "type": "object",
  "required": ["product_code", "product_family", "description", "material", "diameter_mm", "length_mm"],
  "properties": {
    "product_code": {
      "type": "string",
      "pattern": "^[A-Z]{2,4}-[A-Z0-9-]+$",
      "description": "Unique product identifier"
    },
    "product_family": {
      "type": "string",
      "enum": [
        "hex_bolt", "socket_head_cap", "hex_nut", "lock_nut",
        "flat_washer", "spring_washer", "countersunk_screw",
        "self_tapping_screw", "set_screw", "thread_stud",
        "threaded_rod", "anchor_bolt", "flange_bolt",
        "carriage_bolt", "u_bolt", "eye_bolt", "rivet"
      ],
      "description": "Product family classification"
    },
    "description": {
      "type": "string",
      "maxLength": 200,
      "description": "Human-readable product description"
    },
    "standard": {
      "type": "string",
      "description": "Applicable standard (ISO, DIN, ETA, etc.)"
    },
    "material": {
      "type": "string",
      "enum": [
        "carbon_steel", "alloy_steel", "stainless_a2", "stainless_a4",
        "spring_steel", "aluminium", "brass", "titanium"
      ],
      "description": "Base material"
    },
    "finish": {
      "type": "string",
      "enum": [
        "zinc_plated", "hot_dip_galvanized", "passivated",
        "black_oxide", "anodized", "polished", "geomet",
        "dacromet", "plain"
      ],
      "description": "Surface finish / coating"
    },
    "grade": {
      "type": ["string", "null"],
      "description": "Strength grade (e.g. 8.8, 10.9, 12.9, A2-70, A4-80)"
    },
    "thread_type": {
      "type": ["string", "null"],
      "enum": ["full", "partial", "self_tapping", null],
      "description": "Thread coverage"
    },
    "drive_type": {
      "type": ["string", "null"],
      "enum": [
        "hex_external", "hex_socket", "phillips", "torx",
        "square_neck", "slotted", null
      ],
      "description": "Drive / head engagement type"
    },
    "diameter_mm": {
      "type": "number",
      "minimum": 0.1,
      "description": "Nominal diameter in millimeters"
    },
    "length_mm": {
      "type": "number",
      "minimum": 0.1,
      "description": "Total length in millimeters"
    },
    "thread_pitch_mm": {
      "type": ["number", "null"],
      "minimum": 0.1,
      "description": "Thread pitch in millimeters"
    },
    "head_height_mm": {
      "type": ["number", "null"],
      "minimum": 0.1,
      "description": "Head height in millimeters"
    },
    "across_flats_mm": {
      "type": ["number", "null"],
      "minimum": 0.1,
      "description": "Across-flats dimension in millimeters"
    },
    "weight_kg": {
      "type": "number",
      "minimum": 0,
      "description": "Unit weight in kilograms"
    },
    "tensile_strength_mpa": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Minimum tensile strength in MPa"
    },
    "yield_strength_mpa": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Minimum yield strength in MPa"
    },
    "hardness_hrc": {
      "type": ["string", "null"],
      "description": "Rockwell C hardness range (e.g. '22-32')"
    },
    "operating_temp_min_c": {
      "type": "integer",
      "description": "Minimum operating temperature in Celsius"
    },
    "operating_temp_max_c": {
      "type": "integer",
      "description": "Maximum operating temperature in Celsius"
    },
    "corrosion_resistance": {
      "type": "string",
      "enum": ["low", "moderate", "high", "very_high"],
      "description": "Corrosion resistance classification"
    },
    "application": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Intended application areas"
    },
    "approved_uses": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Approved environmental use contexts"
    },
    "unit_price_eur": {
      "type": "number",
      "minimum": 0,
      "description": "Unit price in EUR (list price)"
    },
    "price_tier_100": {
      "type": "number",
      "minimum": 0,
      "description": "Price per unit at 100+ quantity"
    },
    "price_tier_1000": {
      "type": "number",
      "minimum": 0,
      "description": "Price per unit at 1000+ quantity"
    },
    "price_tier_10000": {
      "type": "number",
      "minimum": 0,
      "description": "Price per unit at 10000+ quantity"
    },
    "lead_time_days": {
      "type": "integer",
      "minimum": 0,
      "description": "Standard lead time in business days"
    },
    "moq": {
      "type": "integer",
      "minimum": 1,
      "description": "Minimum order quantity"
    },
    "supplier_code": {
      "type": "string",
      "description": "Internal supplier identifier"
    },
    "supplier_name": {
      "type": "string",
      "description": "Supplier company name"
    },
    "country_of_origin": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "ISO 3166-1 alpha-2 country code"
    },
    "inventory_qty": {
      "type": "integer",
      "minimum": 0,
      "description": "Current inventory quantity"
    },
    "reorder_point": {
      "type": "integer",
      "minimum": 0,
      "description": "Inventory level that triggers reorder"
    },
    "reorder_qty": {
      "type": "integer",
      "minimum": 0,
      "description": "Standard reorder quantity"
    },
    "warehouse_location": {
      "type": "string",
      "description": "Physical warehouse location code"
    },
    "last_receipt_date": {
      "type": "string",
      "format": "date",
      "description": "Date of last inventory receipt"
    },
    "defined_by": {
      "type": "string",
      "description": "Team/person who defined this product"
    },
    "defined_at": {
      "type": "string",
      "format": "date",
      "description": "Date this product was first defined"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Product definition version"
    },
    "review_date": {
      "type": "string",
      "format": "date",
      "description": "Next scheduled review date"
    }
  }
}
