{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Customer View Schema",
  "description": "What the customer sees: product info, specs for selection, pricing, availability. No internal costs, supplier details, or inventory logistics.",
  "type": "object",
  "required": ["product_code", "description", "material", "finish", "diameter_mm", "length_mm"],
  "properties": {
    "product_code": {
      "type": "string",
      "description": "Product identifier for ordering"
    },
    "product_family": {
      "type": "string",
      "description": "Product category"
    },
    "description": {
      "type": "string",
      "description": "Human-readable product name"
    },
    "standard": {
      "type": "string",
      "description": "Applicable standard (ISO, DIN)"
    },
    "material": {
      "type": "string",
      "description": "Material type"
    },
    "finish": {
      "type": "string",
      "description": "Surface finish"
    },
    "grade": {
      "type": ["string", "null"],
      "description": "Strength grade"
    },
    "thread_type": {
      "type": ["string", "null"],
      "description": "Thread coverage"
    },
    "drive_type": {
      "type": ["string", "null"],
      "description": "Drive type"
    },
    "diameter_mm": {
      "type": "number",
      "description": "Nominal diameter (mm)"
    },
    "length_mm": {
      "type": "number",
      "description": "Length (mm)"
    },
    "thread_pitch_mm": {
      "type": ["number", "null"],
      "description": "Thread pitch (mm)"
    },
    "weight_kg": {
      "type": "number",
      "description": "Unit weight (kg)"
    },
    "corrosion_resistance": {
      "type": "string",
      "description": "Corrosion resistance level"
    },
    "application": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suitable applications"
    },
    "approved_uses": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Approved environments"
    },
    "unit_price_eur": {
      "type": "number",
      "description": "List price (EUR)"
    },
    "lead_time_days": {
      "type": "integer",
      "description": "Expected delivery time (business days)"
    },
    "moq": {
      "type": "integer",
      "description": "Minimum order quantity"
    },
    "country_of_origin": {
      "type": "string",
      "description": "Country of manufacture"
    }
  },
  "_view_metadata": {
    "source_schema": "source_schema.json",
    "excluded_fields": [
      "head_height_mm", "across_flats_mm",
      "tensile_strength_mpa", "yield_strength_mpa", "hardness_hrc",
      "operating_temp_min_c", "operating_temp_max_c",
      "price_tier_100", "price_tier_1000", "price_tier_10000",
      "supplier_code", "supplier_name",
      "inventory_qty", "reorder_point", "reorder_qty",
      "warehouse_location", "last_receipt_date",
      "defined_by", "defined_at", "version", "review_date"
    ],
    "reason": "Customers see product selection data and list pricing only. No volume tiers, internal supplier info, or inventory data."
  }
}
