{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Management View Schema",
  "description": "What management sees: KPIs, inventory health, supplier relationships, pricing overview, governance metadata. No deep engineering dimensions.",
  "type": "object",
  "required": ["product_code", "description", "unit_price_eur", "inventory_qty", "supplier_name"],
  "properties": {
    "product_code": {
      "type": "string",
      "description": "Product identifier"
    },
    "product_family": {
      "type": "string",
      "description": "Product category"
    },
    "description": {
      "type": "string",
      "description": "Product name"
    },
    "material": {
      "type": "string",
      "description": "Material type"
    },
    "finish": {
      "type": "string",
      "description": "Surface finish"
    },
    "grade": {
      "type": ["string", "null"],
      "description": "Strength grade"
    },
    "weight_kg": {
      "type": "number",
      "description": "Unit weight (kg)"
    },
    "corrosion_resistance": {
      "type": "string",
      "description": "Corrosion resistance level"
    },
    "application": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Application areas"
    },
    "unit_price_eur": {
      "type": "number",
      "description": "List price (EUR)"
    },
    "price_tier_100": {
      "type": "number",
      "description": "Price at 100+ qty"
    },
    "price_tier_1000": {
      "type": "number",
      "description": "Price at 1000+ qty"
    },
    "price_tier_10000": {
      "type": "number",
      "description": "Price at 10000+ qty"
    },
    "lead_time_days": {
      "type": "integer",
      "description": "Standard lead time (business days)"
    },
    "moq": {
      "type": "integer",
      "description": "Minimum order quantity"
    },
    "supplier_code": {
      "type": "string",
      "description": "Supplier identifier"
    },
    "supplier_name": {
      "type": "string",
      "description": "Supplier company name"
    },
    "country_of_origin": {
      "type": "string",
      "description": "Country of manufacture"
    },
    "inventory_qty": {
      "type": "integer",
      "description": "Current stock level"
    },
    "reorder_point": {
      "type": "integer",
      "description": "Reorder trigger level"
    },
    "reorder_qty": {
      "type": "integer",
      "description": "Standard reorder quantity"
    },
    "warehouse_location": {
      "type": "string",
      "description": "Physical warehouse location"
    },
    "last_receipt_date": {
      "type": "string",
      "format": "date",
      "description": "Date of last receipt"
    },
    "defined_by": {
      "type": "string",
      "description": "Who defined this product"
    },
    "defined_at": {
      "type": "string",
      "format": "date",
      "description": "When defined"
    },
    "version": {
      "type": "integer",
      "description": "Definition version"
    },
    "review_date": {
      "type": "string",
      "format": "date",
      "description": "Next review date"
    }
  },
  "_view_metadata": {
    "source_schema": "source_schema.json",
    "excluded_fields": [
      "standard", "thread_type", "drive_type",
      "diameter_mm", "length_mm", "thread_pitch_mm",
      "head_height_mm", "across_flats_mm",
      "tensile_strength_mpa", "yield_strength_mpa", "hardness_hrc",
      "operating_temp_min_c", "operating_temp_max_c",
      "approved_uses"
    ],
    "reason": "Management needs commercial overview, inventory health, supplier relationships, and governance. No detailed engineering dimensions or mechanical properties."
  }
}
