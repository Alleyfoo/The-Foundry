{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sales View Schema",
  "description": "What sales sees: product basics, all pricing tiers, availability, supplier info, lead times. No deep engineering specs or governance metadata.",
  "type": "object",
  "required": ["product_code", "description", "unit_price_eur", "inventory_qty", "lead_time_days"],
  "properties": {
    "product_code": {
      "type": "string",
      "description": "Product identifier"
    },
    "product_family": {
      "type": "string",
      "description": "Product category"
    },
    "description": {
      "type": "string",
      "description": "Product name"
    },
    "standard": {
      "type": "string",
      "description": "Applicable standard"
    },
    "material": {
      "type": "string",
      "description": "Material type"
    },
    "finish": {
      "type": "string",
      "description": "Surface finish"
    },
    "grade": {
      "type": ["string", "null"],
      "description": "Strength grade"
    },
    "diameter_mm": {
      "type": "number",
      "description": "Nominal diameter (mm)"
    },
    "length_mm": {
      "type": "number",
      "description": "Length (mm)"
    },
    "weight_kg": {
      "type": "number",
      "description": "Unit weight (kg)"
    },
    "corrosion_resistance": {
      "type": "string",
      "description": "Corrosion resistance level"
    },
    "application": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suitable applications"
    },
    "approved_uses": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Approved environments"
    },
    "unit_price_eur": {
      "type": "number",
      "description": "List price (EUR)"
    },
    "price_tier_100": {
      "type": "number",
      "description": "Price at 100+ qty"
    },
    "price_tier_1000": {
      "type": "number",
      "description": "Price at 1000+ qty"
    },
    "price_tier_10000": {
      "type": "number",
      "description": "Price at 10000+ qty"
    },
    "lead_time_days": {
      "type": "integer",
      "description": "Standard lead time (business days)"
    },
    "moq": {
      "type": "integer",
      "description": "Minimum order quantity"
    },
    "supplier_code": {
      "type": "string",
      "description": "Supplier identifier"
    },
    "supplier_name": {
      "type": "string",
      "description": "Supplier company name"
    },
    "country_of_origin": {
      "type": "string",
      "description": "Country of manufacture"
    },
    "inventory_qty": {
      "type": "integer",
      "description": "Current stock level"
    }
  },
  "_view_metadata": {
    "source_schema": "source_schema.json",
    "excluded_fields": [
      "thread_type", "drive_type", "thread_pitch_mm",
      "head_height_mm", "across_flats_mm",
      "tensile_strength_mpa", "yield_strength_mpa", "hardness_hrc",
      "operating_temp_min_c", "operating_temp_max_c",
      "reorder_point", "reorder_qty",
      "warehouse_location", "last_receipt_date",
      "defined_by", "defined_at", "version", "review_date"
    ],
    "reason": "Sales needs pricing tiers, availability, and supplier info. No internal reorder logistics or deep engineering specs."
  }
}
